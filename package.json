{
  "name": "wordle-stats",
  "version": "1.7.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun scripts/build.js",
    "check": "bun run typecheck && bun run lint && bun run test",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "serve": "bun run build && bun scripts/serve.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/bun": "^1.3.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.0"
  }
}
